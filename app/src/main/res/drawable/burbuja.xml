<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Fondo de la burbuja -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF"/>
            <corners android:radius="20dp"/>
            <stroke
                android:width="2dp"
                android:color="#E0E0E0"/>
            <padding
                android:left="12dp"
                android:top="12dp"
                android:right="12dp"
                android:bottom="20dp"/>
        </shape>
    </item>

    <!-- Pico de la burbuja -->
    <item
        android:bottom="0dp"
        android:left="50dp">

        <rotate android:fromDegrees="45">
            <shape android:shape="rectangle">
                <solid android:color="#FFFFFF"/>
                <size
                    android:width="20dp"
                    android:height="20dp"/>
                <stroke
                    android:width="2dp"
                    android:color="#E0E0E0"/>
            </shape>
        </rotate>

    </item>

</layer-list>