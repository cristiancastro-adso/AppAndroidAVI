<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F3F7">

    <!-- BURBUJA -->
    <ImageView
        android:id="@+id/burbujaGato"
        android:layout_width="170dp"
        android:layout_height="170dp"
        android:layout_marginTop="30dp"
        android:src="@drawable/burbuja"
        android:scaleType="fitCenter"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/cardResultados"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- TEXTO BURBUJA -->
    <TextView
        android:id="@+id/txtBurbuja"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#3A3A5A"
        android:textSize="13sp"
        android:gravity="center"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="@id/burbujaGato"
        app:layout_constraintBottom_toBottomOf="@id/burbujaGato"
        app:layout_constraintStart_toStartOf="@id/burbujaGato"
        app:layout_constraintEnd_toEndOf="@id/burbujaGato"/>

    <!-- GATO -->
    <ImageView
        android:id="@+id/imgGato"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/gato"
        android:scaleType="fitCenter"
        app:layout_constraintTop_toTopOf="@id/burbujaGato"
        app:layout_constraintBottom_toBottomOf="@id/burbujaGato"
        app:layout_constraintStart_toStartOf="@id/burbujaGato"
        app:layout_constraintEnd_toEndOf="@id/burbujaGato"
        app:layout_constraintVertical_bias="1.0"/>

    <!-- CARD PRINCIPAL -->
    <LinearLayout
        android:id="@+id/cardResultados"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        android:background="@drawable/bg_card_white"
        android:orientation="vertical"
        android:padding="20dp"
        android:elevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/burbujaGato"
        app:layout_constraintBottom_toTopOf="@id/btnVerInfo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- TITULO -->
                <TextView
                    android:id="@+id/txtTitulo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Programas recomendados"
                    android:textColor="#2C2C54"
                    android:textSize="22sp"
                    android:textStyle="bold"/>

                <!-- LINEA DECORATIVA -->
                <View
                    android:layout_width="50dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="6dp"
                    android:background="#4A6CF7"/>

                <!-- RESULTADOS -->

                <!-- SUBTITULO -->

                <!-- CONTENEDOR -->
                <LinearLayout
                    android:id="@+id/layoutRecomendaciones"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical"/>

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

    <!-- BOTON -->
    <Button
        android:id="@+id/btnVerInfo"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_boton_moderno"
        android:text="Ver en el mapa"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/linearLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- BOTTOM NAV -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_nav_bottom"
        android:elevation="3dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/btnusuario"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:background="@android:color/transparent"
            android:scaleType="centerInside"
            android:src="@drawable/icon_user_new"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnhome"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btnhome"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:background="@android:color/transparent"
            android:scaleType="centerInside"
            android:src="@drawable/icon_home_new"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnusuario"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>