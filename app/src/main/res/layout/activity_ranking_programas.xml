<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_pkm">

    <!-- HEADER ORIGINAL CON GATO -->
    <LinearLayout
        android:id="@+id/linearLayout10"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:elevation="4dp"
        android:background="@drawable/degradado_header"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/gato" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Califica tus Programas"
                android:textColor="@color/moradosena"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/subTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/formacion"
                android:textColor="@color/moradosena"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- SCROLL -->
    <ScrollView
        android:id="@+id/scrollRanking"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/linearLayout10"
        app:layout_constraintBottom_toTopOf="@id/btnGuardarRanking"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="20dp">


            <!-- CARD EXPLICACION -->
            <TextView
                android:id="@+id/txtMetodologia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_white"
                android:elevation="3dp"
                android:gravity="center"
                android:padding="12dp"
                android:layout_marginBottom="20dp"
                android:text="Selecciona tus programas en orden de preferencia. Define cuál sería tu primera, segunda y tercera opción según tus intereses."
                android:textColor="@color/moradosena"
                android:textSize="14sp" />

            <!-- PRIMER -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFF3CD">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/txtPrograma1"
                        android:text="🥇 Primer lugar"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#B8860B"/>

                    <Spinner
                        android:id="@+id/spinnerPrimero"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/spinner_background"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- SEGUNDO -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#ECEFF1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/txtPrograma2"
                        android:text="🥈 Segundo lugar"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#546E7A"/>

                    <Spinner
                        android:id="@+id/spinnerSegundo"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/spinner_background"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- TERCERO -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FBE9E7">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/txtPrograma3"
                        android:text="🥉 Tercer lugar"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#6D4C41"/>

                    <Spinner
                        android:id="@+id/spinnerTercero"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/spinner_background"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

    <!-- BOTON -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGuardarRanking"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:layout_margin="20dp"
        android:elevation="4dp"
        android:text="Guardar Preferencia"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="@android:color/white"
        android:background="@drawable/btnfondo"
        app:backgroundTint="@null"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
