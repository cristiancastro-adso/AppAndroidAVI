<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_pkm">


    <LinearLayout
        android:id="@+id/linearLayout10"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:elevation="4dp"
        android:background="@drawable/degradado_header"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/gato" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Califica tus Programas"
                android:textColor="@color/moradosena"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/subTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/formacion"
                android:textColor="@color/moradosena"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- SCROLL -->
    <ScrollView
        android:id="@+id/scrollRanking"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/linearLayout10"
        app:layout_constraintBottom_toTopOf="@id/btnGuardarRanking"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="20dp">


            <!-- CARD EXPLICACION -->
            <TextView
                android:id="@+id/txtMetodologia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_white"
                android:elevation="3dp"
                android:gravity="center"
                android:padding="20dp"
                android:layout_margin="12dp"
                android:layout_marginBottom="20dp"
                android:text="Selecciona los programas y define cuál sería tu primera, segunda y tercera opción según tus intereses."
                android:textColor="@color/gris"
                android:textSize="17sp" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp">

                <!-- IMAGEN -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgPodio"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:src="@drawable/podio4"
                    android:scaleType="fitCenter"
                    android:adjustViewBounds="true"

                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"

                    app:shapeAppearanceOverlay="@style/RoundedImage"/>

                <!-- 🥇 PRIMER LUGAR (barra superior) -->
                <Spinner
                    android:id="@+id/spinnerPrimero"
                    android:layout_width="225dp"
                    android:layout_height="23dp"
                    android:background="@android:color/transparent"

                    app:layout_constraintTop_toTopOf="@id/imgPodio"
                    app:layout_constraintBottom_toBottomOf="@id/imgPodio"
                    app:layout_constraintStart_toStartOf="@id/imgPodio"
                    app:layout_constraintEnd_toEndOf="@id/imgPodio"

                    app:layout_constraintVertical_bias="0.6"
                    app:layout_constraintHorizontal_bias="0.5"
                    app:layout_constraintWidth_percent="0.75"/>

                <!-- 🥈 SEGUNDO LUGAR -->
                <Spinner
                    android:id="@+id/spinnerSegundo"
                    android:layout_width="225dp"
                    android:layout_height="23dp"
                    android:background="@android:color/transparent"

                    app:layout_constraintTop_toTopOf="@id/imgPodio"
                    app:layout_constraintBottom_toBottomOf="@id/imgPodio"
                    app:layout_constraintStart_toStartOf="@id/imgPodio"
                    app:layout_constraintEnd_toEndOf="@id/imgPodio"

                    app:layout_constraintVertical_bias="0.705"
                    app:layout_constraintWidth_percent="0.75"/>

                <!-- 🥉 TERCER LUGAR -->
                <Spinner
                    android:id="@+id/spinnerTercero"
                    android:layout_width="225dp"
                    android:layout_height="23dp"
                    android:background="@android:color/transparent"

                    app:layout_constraintTop_toTopOf="@id/imgPodio"
                    app:layout_constraintBottom_toBottomOf="@id/imgPodio"
                    app:layout_constraintStart_toStartOf="@id/imgPodio"
                    app:layout_constraintEnd_toEndOf="@id/imgPodio"

                    app:layout_constraintVertical_bias="0.82"
                    app:layout_constraintWidth_percent="0.75"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>

    </ScrollView>

    <!-- BOTON -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGuardarRanking"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:layout_margin="20dp"
        android:elevation="4dp"
        android:text="Guardar Preferencia"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="@android:color/white"
        android:background="@drawable/btnfondo"
        app:backgroundTint="@null"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
