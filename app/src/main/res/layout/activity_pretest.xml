<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_pkm">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/linearLayout10"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:elevation="4dp"
        android:background="@drawable/degradado_header"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/gato" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pre-Test"
                android:textColor="@color/moradosena"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/subTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/formacion"
                android:textColor="@color/moradosena"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- CONTENIDO CON SCROLL -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:background="#EDE7F6"
        app:layout_constraintTop_toBottomOf="@id/linearLayout10"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="10dp"
            android:layout_margin="10dp">

            <!-- CONTENEDOR AVATAR Y MICROFONO -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginBottom="20dp">

                <WebView
                    android:id="@+id/webAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginRight="20dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnMicrofono"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="20dp"
                    android:layout_marginBottom="20dp"
                    android:contentDescription="Hablar"
                    app:backgroundTint="@color/moradosena"
                    app:fabSize="normal"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:srcCompat="@android:drawable/ic_btn_speak_now"
                    app:tint="@color/white"
                    />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- PREGUNTA 1 -->
            <TextView
                android:id="@+id/lblPregunta1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. ¿Qué querías ser cuando eras niño/a y por qué?"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#1E1E1E"
                android:layout_marginBottom="6dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground" />

            <EditText
                android:id="@+id/pregunta1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edtbg"
                android:hint="Escribe tu respuesta..."
                android:minLines="3"
                android:padding="14dp"
                android:layout_marginBottom="20dp"
                android:elevation="3dp"
                android:inputType="textMultiLine"
                android:importantForAutofill="no" />

            <!-- PREGUNTA 2 -->
            <TextView
                android:id="@+id/lblPregunta2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="2. Si tuvieras que elegir una actividad para hacer 4 horas seguidas sin aburrirte, ¿cuál sería?"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#1E1E1E"
                android:layout_marginBottom="6dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground" />

            <EditText
                android:id="@+id/pregunta2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edtbg"
                android:hint="Escribe tu respuesta..."
                android:minLines="3"
                android:padding="14dp"
                android:layout_marginBottom="20dp"
                android:elevation="3dp"
                android:inputType="textMultiLine"
                android:importantForAutofill="no" />

            <!-- PREGUNTA 3 -->
            <TextView
                android:id="@+id/lblPregunta3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="3. ¿Qué tipo de problemas disfrutas resolver más?"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#1E1E1E"
                android:layout_marginBottom="6dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground" />

            <RadioGroup
                android:id="@+id/pregunta3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">
                <RadioButton android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Técnicos o mecánicos"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Científicos o de investigación"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Creativos o artísticos"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Personales o sociales"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Comerciales o estratégicos"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Administrativos u organizativos"/>
            </RadioGroup>

            <!-- PREGUNTA 4 -->
            <TextView
                android:id="@+id/lblPregunta4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="4. En un trabajo ideal, ¿qué valoras más?"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#1E1E1E"
                android:layout_marginBottom="6dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground" />

            <RadioGroup
                android:id="@+id/pregunta4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">
                <RadioButton android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Estabilidad y orden"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Libertad creativa"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Impacto en otras personas"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Liderar proyectos"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Descubrir cosas nuevas"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Trabajar con tecnología"/>
            </RadioGroup>

            <!-- PREGUNTA 5 -->
            <TextView
                android:id="@+id/lblPregunta5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="5. Cuando trabajas en equipo, ¿qué rol asumes naturalmente?"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#1E1E1E"
                android:layout_marginBottom="6dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground" />

            <RadioGroup
                android:id="@+id/pregunta5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="30dp">
                <RadioButton android:layout_width="match_parent" android:layout_height="wrap_content" android:text="El que organiza"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="wrap_content" android:text="El que propone ideas"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="wrap_content" android:text="El que analiza"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="wrap_content" android:text="El que ejecuta"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="wrap_content" android:text="El que lidera"/>
                <RadioButton android:layout_width="match_parent" android:layout_height="wrap_content" android:text="El que apoya"/>
            </RadioGroup>

            <!-- BOTÓN -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginBottom="20dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnContinuarTest"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Continuar"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/btnfondo"
                    app:backgroundTint="@null"
                    app:cornerRadius="16dp"/>

                <ProgressBar
                    android:id="@+id/progressContinuar"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:visibility="gone"/>

            </FrameLayout>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
